ol_plane:\n      hosts:\n        master-1:\n    \n    kube_node:\n      hosts:\n        worker-1:\n        worker-2:\n    \n    # Kubespray requires an etcd group. It's standard to run etcd on the control plane nodes.\n    etcd:\n      hosts:\n        master-1:\n    \n    k8s_cluster:\n      children:\n        kube_control_plane: {}\n        kube_node: {}\n        \n    cilium_rr:\n      hosts: {}","content_base64":null,"content_base64sha256":"Ky+lhsHrXzC9f4vVE2oHM/SeWHdCBavtZ0sqWiGr8rc=","content_base64sha512":"7/rQvyJJ/u9FHdkJ3AyWSkz8wpafC+/kQ948DRaVFjEgfmZ9BfdtAr6s1b2hXYgTUStwP4hHbSoLYLHQaZ+KEQ==","content_md5":"8987f80f2178e964b440034d3adf8ce0","content_sha1":"015fd7d5cc18b64e3c6d916a50694647af28524c","content_sha256":"2b2fa586c1eb5f30bd7f8bd5136a0733f49e58774205abed674b2a5a21abf2b7","content_sha512":"effad0bf2249feef451dd909dc0c964a4cfcc2969f0befe443de3c0d16951631207e667d05f76d02beacd5bda15d8813512b703f88476d2a0b60b1d0699f8a11","directory_permission":"0777","file_permission":"0777","filename":"/home/msi/Vscode/Ansible/My-project/kubespray/inventory/mycluster/inventory.yaml","id":"015fd7d5cc18b64e3c6d916a50694647af28524c","sensitive_content":null,"source":null},"sensitive_attributes":[[{"type":"get_attr","value":"sensitive_content"}]],"dependencies":["data.external.master_ips","data.external.worker_ips","libvirt_cloudinit_disk.vm_init","libvirt_domain.Master","libvirt_domain.Worker","libvirt_volume.ubuntu_base","libvirt_volume.vm_cloudinit","libvirt_volume.vm_disk"]}]}],"check_results":null}
